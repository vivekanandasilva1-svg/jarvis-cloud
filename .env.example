# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=

# --- Meta Marketing API (Gerenciador de Anuncios) ---
# JSON com um ou mais tokens de Usuario do Sistema, um por empresa/portfolio empresarial:
# [{"label":"nome da empresa","token":"..."}, ...]
META_ADS_TOKENS=

# --- Clinicorp (Acesso Externo e Integracoes > Integracao via API) ---
CLINICORP_API_USER=
CLINICORP_API_TOKEN=
CLINICORP_SUBSCRIBER_ID=
CLINICORP_DEFAULT_BUSINESS_ID=
CLINICORP_CODE_LINK=

# --- Trello (trello.com/power-ups/admin > gerar API Key, e usar ela na URL de autorizacao
# pra gerar o Token: trello.com/1/authorize?expiration=never&scope=read,write&response_type=token&key=SUA_API_KEY) ---
TRELLO_API_KEY=
TRELLO_TOKEN=

# --- Google AI Studio / Gemini (voz + transcricao de audio) ---
# pega gratis em aistudio.google.com/apikey
GEMINI_API_KEY=

# --- Whisper auto-hospedado (opcional - transcricao de audio sem custo por uso nem cota) ---
# so preencher em ambientes que tem um servidor Whisper rodando ao lado (ex: a VPS, via
# Docker/Easypanel) - deixando vazio, a transcricao cai pro Gemini normalmente
WHISPER_URL=

# --- WhatsApp Business Cloud API (Meta for Developers > seu app > WhatsApp) ---
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# token que voce mesmo inventa e usa nos dois lados (aqui e na configuracao do webhook no
# painel da Meta) - so serve pra confirmar que a configuracao do webhook e legitima
WHATSAPP_VERIFY_TOKEN=
# App Secret do app da Meta (Configuracoes > Basico) - usado pra validar a assinatura das
# mensagens recebidas no webhook
WHATSAPP_APP_SECRET=
# numeros (com DDI, so digitos, ex: 5582999999999) autorizados a conversar com a Lumia pelo
# WhatsApp, separados por virgula
WHATSAPP_ALLOWED_NUMBERS=

# --- Senha de acesso ao app (obrigatorio em producao) ---
APP_PASSWORD=

# --- Porta (o Render define isso sozinho, nao precisa mexer) ---
PORT=4000
